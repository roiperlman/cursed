{
  "compilerOptions": {
    "target": "ES2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "lib": ["ES2022"]
  },
  "include": ["scripts/**/*.mjs", "test/**/*.mjs", "scripts/**/*.d.ts", "tools/**/*.mjs"],
  "exclude": ["scripts/**/*.bundled.mjs", "scripts/run-advise-testbed.mjs", "test/e2e/**", "test/integration/**"]
}
